// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Gender {
  M
  F
}

enum TournamentStatus {
  DRAFT
  PUBLISHED
  CANCELLED
  ARCHIVED
}

enum GroundType {
  BOX
  OPEN
}

enum BallType {
  TENNIS
  LEATHER
}

model User {
  id          String    @id @default(uuid()) @db.Uuid
  name        String?
  phoneNumber String    @unique
  email       String?   @unique
  gender      Gender?
  dateOfBirth DateTime? @db.Date
  isDeleted   Boolean   @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tournaments         Tournament[]
  tournamentContacts  TournamentContact[]

  @@map("users")
}

model Otp {
  id          String   @id @default(uuid()) @db.Uuid
  phoneNumber String
  otp         String
  expiresAt   DateTime
  isUsed      Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@map("otps")
}

model Sport {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tournaments Tournament[]

  @@map("sports")
}

model City {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  state     String
  country   String
  placeId   String   @unique
  latitude  Float?
  longitude Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  venues Venue[]

  @@map("cities")
}

model Venue {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  cityId    String   @db.Uuid
  city      City     @relation(fields: [cityId], references: [id])
  address   String?
  latitude  Float?
  longitude Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tournaments Tournament[]

  @@map("venues")
}

model Tournament {
  id                      String    @id @default(uuid()) @db.Uuid
  name                    String
  venueId                 String    @db.Uuid
  venue                   Venue     @relation(fields: [venueId], references: [id])
  organiserId             String    @db.Uuid
  organiser               User      @relation(fields: [organiserId], references: [id])
  sportId                 String    @db.Uuid
  sport                   Sport     @relation(fields: [sportId], references: [id])
  tournamentStartDate     DateTime? @db.Date
  tournamentEndDate       DateTime? @db.Date
  registrationStartDate   DateTime? @db.Date
  registrationEndDate     DateTime? @db.Date
  description             String?
  status                  TournamentStatus @default(DRAFT)
  isDeleted               Boolean   @default(false)
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  contacts      TournamentContact[]
  cricketConfig CricketConfig?

  @@map("tournaments")
}

model TournamentContact {
  id           String     @id @default(uuid()) @db.Uuid
  tournamentId String     @db.Uuid
  tournament   Tournament @relation(fields: [tournamentId], references: [id])
  userId       String     @db.Uuid
  user         User       @relation(fields: [userId], references: [id])
  isDeleted    Boolean    @default(false)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([tournamentId, userId])
  @@map("tournament_contacts")
}

model CricketConfig {
  id             String     @id @default(uuid()) @db.Uuid
  tournamentId   String     @unique @db.Uuid
  tournament     Tournament @relation(fields: [tournamentId], references: [id])
  groundType     GroundType
  ballType       BallType
  numberOfTeams  Int
  playersPerTeam Int
  auctionBased      Boolean  @default(false)
  auctionPurse      Int?
  playerBasePrice   Int?
  isDeleted      Boolean    @default(false)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@map("cricket_configs")
}
